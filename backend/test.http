Content-Type: application/json

{
  "code": "import java.util.Scanner;\npublic class Hello { public static void main(String[] args) { Scanner scanner = new Scanner(System.in); String name = scanner.nextLine(); System.out.println(\"Hello \" + name); } }",
  "language": "java",
  "stdin": "Testing input in java..."
}

####C-input###
