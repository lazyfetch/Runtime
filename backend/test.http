}


###JavaScript-input###
POST http://localhost:8081/api/execute
Content-Type: application/json

{
  "code": "process.stdin.resume();\nprocess.stdin.setEncoding('utf8');\nprocess.stdin.on('data', (name) => { console.log(`Hello ${name.trim()}`); });",
  "language": "js",
  "stdin": "TestinginputinJavaScript..."
}

